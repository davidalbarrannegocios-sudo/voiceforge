# Price IDs de los productos que crees en Stripe
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_STUDIO=

# RunPod - https://runpod.io/console/serverless
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# OpenAI - https://platform.openai.com/api-keys (usado para traducción de audio)
OPENAI_API_KEY=

# Cloudflare R2 - https://dash.cloudflare.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=voiceforge
