generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String                 @id @default(cuid())
  clerkId               String                 @unique
  email                 String
  credits               Int                    @default(0)
  referralCode          String?                @unique
  referredBy            String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  role                  String                 @default("user")
  plan                  String                 @default("free")
  planExpiresAt         DateTime?
  stripeCustomerId      String?                @unique
  stripeSubscriptionId  String?                @unique
  transcriptionUsed     Int                    @default(0)
  extraCredits          Int                    @default(0)
  billingInterval       String                 @default("monthly")
  creditsRenewedAt      DateTime?
  referralBalance       Int                    @default(0)
  referralEarned        Int                    @default(0)
  referralPending       Int                    @default(0)
  stripePriceId         String?
  cancelAtPeriodEnd     Boolean                @default(false)
  stripeStatus          String?
  disabledUntil         DateTime?
  affiliateType         String    @default("standard")
  hasDiscount           Boolean   @default(false)
  discountPercentage    Int       @default(10)
  discountLabel         String    @default("DESCUENTO")
  language              String                 @default("en")
  affiliateApplications AffiliateApplication[]
  clonedVoices          ClonedVoice[]
  creditPacks           CreditPack[]
  favoriteVoices        FavoriteVoice[]
  generations           Generation[]
  generationJobs        GenerationJob[]
  jobs                  Job[]
  payoutRequests        PayoutRequest[]
  purchases             Purchase[]
  referralReceived          Referral?                @relation("referred")
  referralsGiven            Referral[]               @relation("referrer")
  pendingReferralRewards    PendingReferralReward[]
  supportTickets        SupportTicket[]
  teamOwned             Team?                  @relation("TeamOwner")
  teamMember            TeamMember?
  transcriptionTasks    TranscriptionTask[]
  translationTasks      TranslationTask[]
  userSessions          UserSession[]
  withdrawalRequests    WithdrawalRequest[]
  apiKeys              ApiKey[]
  apiUsageLogs         ApiUsageLog[]
  apiWallet            ApiWallet?
  sharedImages         SharedImage[]
  eliteTextPlan        EliteTextPlan?
  announcementsSeen    AnnouncementSeen[]
}

model Job {
  id              String    @id @default(cuid())
  userId          String
  status          String    @default("pending")
  text            String
  voiceId         String
  audioUrl        String?
  durationSeconds Float?
  error           String?
  creditsUsed     Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  expiresAt       DateTime?
  voiceName       String?
  user            User      @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
}

model Generation {
  id              String    @id @default(cuid())
  userId          String
  text            String
  voiceId         String
  audioUrl        String?
  durationSeconds Float?
  creditsUsed     Int       @default(0)
  createdAt       DateTime  @default(now())
  refunded        Boolean   @default(false)
  expiresAt       DateTime?
  error           String?
  status          String    @default("done")
  voiceName       String?
  user            User      @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
}

model ClonedVoice {
  id                String   @id @default(cuid())
  userId            String
  name              String
  referenceAudioUrl String
  createdAt         DateTime @default(now())
  gender            String   @default("masculine")
  language          String   @default("es")
  isPublic          Boolean  @default(false)
  minimaxVoiceId    String?
  provider          String   @default("fish_audio")
  user              User     @relation(fields: [userId], references: [id])
}

model Purchase {
  id               String   @id @default(cuid())
  userId           String
  stripeSessionId  String   @unique
  creditsPurchased Int
  amountCents      Int
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])
}

model SupportTicket {
  id          String   @id @default(cuid())
  userId      String
  type        String
  description String
  status      String   @default("open")
  adminReply  String?
  messages    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model CreditPack {
  id                    String   @id @default(cuid())
  userId                String
  credits               Int
  expiresAt             DateTime
  stripePaymentIntentId String?  @unique
  createdAt             DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id])
}

model FavoriteVoice {
  id         String   @id @default(cuid())
  userId     String
  voiceId    String
  voiceName  String
  coverImage String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, voiceId])
}

model Team {
  id        String       @id @default(cuid())
  name      String
  ownerId   String       @unique
  createdAt DateTime     @default(now())
  owner     User         @relation("TeamOwner", fields: [ownerId], references: [id])
  members   TeamMember[]
}

model TeamMember {
  id                     String   @id @default(cuid())
  teamId                 String
  userId                 String   @unique
  email                  String
  name                   String?
  percentage             Int      @default(0)
  createdAt              DateTime @default(now())
  creditsLastDistributed Int      @default(0)
  team                   Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user                   User     @relation(fields: [userId], references: [id])
}

model VoicePreview {
  id        String   @id @default(cuid())
  voiceId   String   @unique
  audioUrl  String
  createdAt DateTime @default(now())
}

model Referral {
  id          String    @id @default(cuid())
  referrerId  String
  referredId  String    @unique
  status      String    @default("pending")
  rewardChars Int       @default(0)
  createdAt   DateTime  @default(now())
  rewardedAt  DateTime?
  referred    User      @relation("referred", fields: [referredId], references: [id])
  referrer    User      @relation("referrer", fields: [referrerId], references: [id])
}

model TranscriptionTask {
  id                String   @id @default(cuid())
  userId            String
  fileName          String
  status            String   @default("processing")
  creditsUsed       Int      @default(0)
  speakers          String   @default("auto")
  durationSeconds   Float?
  transcriptionText String?
  errorMessage      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
}

model TranslationTask {
  id                 String    @id @default(cuid())
  userId             String
  fileName           String
  targetLanguage     String
  targetLanguageName String
  status             String    @default("processing")
  creditsUsed        Int       @default(0)
  durationSeconds    Float?
  audioUrl           String?
  transcribedText    String?
  translatedText     String?
  errorMessage       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  expiresAt          DateTime?
  r2Key              String?
  speakerMode        String    @default("single")
  speakerCount       Int?
  user               User      @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
}

model AffiliateApplication {
  id            String   @id @default(cuid())
  name          String
  email         String
  platform      String
  audience      String
  paymentMethod String
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
}

model NicheChannel {
  id                  String   @id @default(cuid())
  ytChannelId         String   @unique
  title               String
  description         String?
  username            String?
  thumbnail           String?
  category            String?
  format              String?
  outlierScore        Float?
  isFaceless          Boolean?
  isAiChannel         Boolean?
  isMonetized         Boolean?
  quality             String?
  tags                String[]
  location            String?
  googleTrendsKeyword String?
  createdAt           String?
  subscribers         Int?
  monthlyRevenue      Float?
  monthlyViews        Int?
  totalViews          Int?
  totalVideos         Int?
  avgViewsPerVideo    Float?
  avgVideoLength      Float?
  uploadsPerWeek      Float?
  rpm                 Float?
  firstVideoDate      String?
  lastVideoDate       String?
  updatedAt           DateTime @updatedAt
}

model WithdrawalRequest {
  id        String    @id @default(cuid())
  userId    String
  amount    Float
  method    String
  details   Json
  status    String    @default("pending")
  createdAt DateTime  @default(now())
  paidAt    DateTime?
  user      User      @relation(fields: [userId], references: [id])
}

model PayoutRequest {
  id          String   @id @default(cuid())
  userId      String
  amountCents Int
  method      String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model GenerationJob {
  id          String   @id @default(cuid())
  userId      String
  status      String   @default("pending")
  voiceId     String   @default("default")
  voiceName   String
  text        String
  fishParams  Json?
  audioUrl    String?
  errorMsg    String?
  creditsUsed Int      @default(0)
  fromPlan    Int      @default(0)
  fromExtra   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
}

model SystemConfig {
  id                           String   @id @default("singleton")
  elitelabsTurboStatus         String   @default("active")
  updatedAt                    DateTime @updatedAt
  elitelabsTurboManualOverride Boolean  @default(false)
  registrationOpen             Boolean  @default(true)
  maintenanceMessage           String   @default("")
  maintenanceMessageActive     Boolean  @default(false)
  planCredits                  String   @default("{}")
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  ip        String?
  userAgent String?
  device    String?
  browser   String?
  os        String?
  country   String?
  city      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
}

model AppLog {
  id        String   @id @default(cuid())
  level     String
  category  String
  message   String
  details   String?
  userId    String?
  requestId String?
  createdAt DateTime @default(now())
}

model ApiKey {
  id         String        @id @default(cuid())
  userId     String
  name       String
  keyHash    String        @unique
  prefix     String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLogs  ApiUsageLog[]

  @@index([userId])
}

model ApiUsageLog {
  id        String   @id @default(cuid())
  userId    String
  apiKeyId  String
  bytes     Int      @default(0)
  endpoint  String
  createdAt DateTime @default(now())
  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([apiKeyId])
}

model ApiWallet {
  id         String   @id @default(cuid())
  userId     String   @unique
  bytes      BigInt   @default(0)
  totalSpent Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SharedImage {
  id          String   @id @default(cuid())
  userId      String
  prompt      String
  model       String
  aspectRatio String
  storageKey  String   @default("")
  imageUrl    String
  type        String   @default("image")
  creditsUsed Int      @default(0)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([expiresAt])
  @@index([userId])
}

model CookieConsent {
  id        String   @id @default(cuid())
  userId    String?
  ip        String?
  consent   String
  consentId String?  // UUID anónimo del navegador
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EliteTextPlan {
  id                   String    @id @default(cuid())
  userId               String    @unique
  plan                 String
  tokensTotal          Int
  tokensUsed           Int       @default(0)
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  status               String    @default("active")
  renewsAt             DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PendingReferralReward {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String
  amount       Int
  pendingUntil DateTime
  createdAt    DateTime @default(now())
  referrer     User     @relation(fields: [referrerId], references: [id])

  @@index([pendingUntil])
  @@index([referredId])
}

model PageVisit {
  id        String   @id @default(cuid())
  ip        String?
  userAgent String?
  country   String?
  path      String   @default("/")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Announcement {
  id        String   @id @default(cuid())
  title     Json
  content   Json
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AnnouncementSeen {
  id             String   @id @default(cuid())
  userId         String
  announcementId String
  seenAt         DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, announcementId])
}
