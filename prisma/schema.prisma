generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String        @id @default(cuid())
  clerkId              String        @unique
  email                String
  credits              Int           @default(0)
  extraCredits         Int           @default(0)
  role                 String        @default("user")
  plan                 String        @default("free")
  planExpiresAt        DateTime?
  stripeCustomerId     String?       @unique
  stripeSubscriptionId String?       @unique
  billingInterval      String        @default("monthly")
  creditsRenewedAt     DateTime?
  transcriptionUsed    Int           @default(0)
  referralCode         String?       @unique
  referredBy           String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  generations          Generation[]
  clonedVoices         ClonedVoice[]
  purchases            Purchase[]
  jobs                 Job[]
  referralsGiven       Referral[]    @relation("referrer")
  referralReceived     Referral?     @relation("referred")
  supportTickets       SupportTicket[]
  creditPacks          CreditPack[]
  favoriteVoices       FavoriteVoice[]
  teamOwned            Team?           @relation("TeamOwner")
  teamMember           TeamMember?
  transcriptionTasks    TranscriptionTask[]
  translationTasks      TranslationTask[]
  referralBalance       Int                    @default(0)
  referralEarned        Int                    @default(0)
  payoutRequests        PayoutRequest[]
  withdrawalRequests    WithdrawalRequest[]
  affiliateApplications AffiliateApplication[]
}

model Job {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  status          String    @default("pending")
  text            String
  voiceId         String
  voiceName       String?
  audioUrl        String?
  durationSeconds Float?
  error           String?
  creditsUsed     Int       @default(0)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Generation {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  text            String
  voiceId         String
  audioUrl        String?
  durationSeconds Float
  creditsUsed     Int
  refunded        Boolean   @default(false)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
}

model ClonedVoice {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  name              String
  referenceAudioUrl String
  language          String   @default("es")
  gender            String   @default("masculine")
  isPublic          Boolean  @default(false)
  provider          String   @default("fish_audio")
  minimaxVoiceId    String?
  createdAt         DateTime @default(now())
}

model Purchase {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  stripeSessionId  String   @unique
  creditsPurchased Int
  amountCents      Int
  createdAt        DateTime @default(now())
}

model SupportTicket {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String
  description String
  status      String   @default("open")
  adminReply  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CreditPack {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id])
  credits               Int
  expiresAt             DateTime
  stripePaymentIntentId String?  @unique
  createdAt             DateTime @default(now())
}

model FavoriteVoice {
  id         String   @id @default(cuid())
  userId     String
  voiceId    String
  voiceName  String
  coverImage String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, voiceId])
}

model Team {
  id        String       @id @default(cuid())
  name      String
  ownerId   String       @unique
  owner     User         @relation("TeamOwner", fields: [ownerId], references: [id])
  members   TeamMember[]
  createdAt DateTime     @default(now())
}

model TeamMember {
  id                     String   @id @default(cuid())
  teamId                 String
  userId                 String   @unique
  email                  String
  name                   String?
  percentage             Int      @default(0)
  creditsLastDistributed Int      @default(0)
  team                   Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user                   User     @relation(fields: [userId], references: [id])
  createdAt              DateTime @default(now())
}

model VoicePreview {
  id        String   @id @default(cuid())
  voiceId   String   @unique
  audioUrl  String
  createdAt DateTime @default(now())
}

model Referral {
  id          String    @id @default(cuid())
  referrerId  String
  referrer    User      @relation("referrer", fields: [referrerId], references: [id])
  referredId  String    @unique
  referred    User      @relation("referred", fields: [referredId], references: [id])
  status      String    @default("pending") // pending | rewarded | claimed
  rewardChars Int       @default(0)
  createdAt   DateTime  @default(now())
  rewardedAt  DateTime?
}

model TranscriptionTask {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  fileName          String
  status            String   @default("processing") // processing | completed | error
  creditsUsed       Int      @default(0)
  speakers          String   @default("auto")
  durationSeconds   Float?
  transcriptionText String?
  errorMessage      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TranslationTask {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id])
  fileName           String
  targetLanguage     String
  targetLanguageName String
  status             String   @default("processing")
  creditsUsed        Int      @default(0)
  durationSeconds    Float?
  audioUrl           String?
  transcribedText    String?
  translatedText     String?
  errorMessage       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AffiliateApplication {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  name          String
  email         String
  platform      String
  audience      String
  paymentMethod String
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WithdrawalRequest {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  amount    Float
  method    String
  details   Json
  status    String    @default("pending")
  createdAt DateTime  @default(now())
  paidAt    DateTime?
}

model PayoutRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amountCents Int
  method      String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
